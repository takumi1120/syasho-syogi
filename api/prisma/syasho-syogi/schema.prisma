generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/syasho-client"
}

datasource db {
  provider = "postgresql"
  url      = env("SYASHO_DATABASE_URL")
}

enum RoomStatus {
  OPEN
  MATCHED
  PLAYING
  CLOSED
}

enum GameMode {
  LOCAL
  ONLINE
  CPU
}

enum GameStatus {
  WAITING
  PLAYING
  FINISHED
  ABORTED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @map("name")
  createdAt DateTime @default(now()) @map("created_at")

  results Result[]

  hostedRooms Room[] @relation("RoomHostUser")
  joinedRooms Room[] @relation("RoomGuestUser")

  gamesAsPlayer1 Game[] @relation("GamePlayer1")
  gamesAsPlayer2 Game[] @relation("GamePlayer2")
  wins           Game[] @relation("GameWinner")

  @@map("users")
}

model Result {
  id        Int      @id @default(autoincrement())
  win       Int      @default(0)
  lose      Int      @default(0)
  userId    Int?     @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("results")
}

model Room {
  id          Int        @id @default(autoincrement())
  roomCode    String     @unique @map("room_code")
  hostUserId  Int        @map("host_user_id")
  guestUserId Int?       @map("guest_user_id")
  status      RoomStatus @default(OPEN)

  hostReady  Boolean @default(false) @map("host_ready")
  guestReady Boolean @default(false) @map("guest_ready")

  hostCharacter  String? @map("host_character")
  guestCharacter String? @map("guest_character")

  gameId Int? @unique @map("game_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  hostUser  User  @relation("RoomHostUser", fields: [hostUserId], references: [id], onDelete: Cascade)
  guestUser User? @relation("RoomGuestUser", fields: [guestUserId], references: [id], onDelete: SetNull)
  game      Game? @relation("RoomGame", fields: [gameId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([hostUserId])
  @@index([guestUserId])
  @@map("rooms")
}

model Game {
  id        Int  @id @default(autoincrement())
  player1Id Int  @map("player1_id")
  player2Id Int  @map("player2_id")
  winnerId  Int? @map("winner_id")

  mode   GameMode   @default(ONLINE)
  status GameStatus @default(WAITING)

  currentTurn Int   @default(1) @map("current_turn")
  boardState  Json? @map("board_state")

  player1Character String? @map("player1_character")
  player2Character String? @map("player2_character")

  startedAt DateTime? @map("started_at")
  endedAt   DateTime? @map("ended_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  player1 User  @relation("GamePlayer1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2 User  @relation("GamePlayer2", fields: [player2Id], references: [id], onDelete: Cascade)
  winner  User? @relation("GameWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  room Room? @relation("RoomGame")

  @@index([player1Id])
  @@index([player2Id])
  @@index([status])
  @@map("games")
}
