{
  "name": "syasho-syogi-api",
  "version": "1.0.0",
  "description": "Unified API for syasho-syogi and gobblet-gobblers",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only ./src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "npx prisma generate --schema=prisma/syasho-syogi/schema.prisma && npx prisma generate --schema=prisma/gobblet-gobblers/schema.prisma",
    "prisma:migrate:syasho": "npx prisma migrate deploy --schema=prisma/syasho-syogi/schema.prisma",
    "prisma:migrate:gobblet": "npx prisma migrate deploy --schema=prisma/gobblet-gobblers/schema.prisma",
    "prisma:migrate:all": "npm run prisma:migrate:syasho && npm run prisma:migrate:gobblet"
  },
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
